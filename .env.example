# ---------------------------------------------------------------------------
# CHAVES DE API
# ---------------------------------------------------------------------------

# IEEE Xplore — https://developer.ieee.org/
IEEE_API_KEY=

# Scopus / Elsevier — https://dev.elsevier.com/
SCOPUS_API_KEY=

# Springer — https://dev.springernature.com/
SPRINGER_API_KEY=

# Semantic Scholar — opcional; sem chave o limite é 100 req/5min
SEMANTIC_SCHOLAR_API_KEY=

# Crossref — não exige chave, mas informar e-mail usa a "Polite Pool" (mais rápida)
CROSSREF_EMAIL=seu_email@ufla.br

# ---------------------------------------------------------------------------
# ATIVAR / DESATIVAR BASES  (true | false)
# ---------------------------------------------------------------------------
SEMANTIC_SCHOLAR_ATIVO=true
ARXIV_ATIVO=true
IEEE_ATIVO=false
SCOPUS_ATIVO=false
SPRINGER_ATIVO=false
CROSSREF_ATIVO=true

# ---------------------------------------------------------------------------
# LIMITES DE RESULTADOS POR BASE
# ---------------------------------------------------------------------------
SEMANTIC_SCHOLAR_MAX_RESULTS=100
ARXIV_MAX_RESULTS=100
IEEE_MAX_RESULTS=200
SCOPUS_MAX_RESULTS=200
SPRINGER_API_KEY=200
CROSSREF_MAX_RESULTS=100

# ---------------------------------------------------------------------------
# SAÍDA
# ---------------------------------------------------------------------------
OUTPUT_DIRETORIO=results
OUTPUT_PREFIXO=msl_ultima_milha
OUTPUT_FORMATO_EXCEL=true
OUTPUT_FORMATO_CSV=true
OUTPUT_LOG_DETALHADO=true
